// ============================================
// STUDYBOND PRISMA SCHEMA
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum AdminAuditAction {
  ROLE_PROMOTED
  ROLE_DEMOTED
  ROLE_PROMOTION_ATTEMPT_FAILED
  ROLE_DEMOTION_ATTEMPT_FAILED
  USER_BANNED
  USER_UNBANNED
  DEVICE_REMOVED
  QUESTION_DELETED
  QUESTION_EDITED
  EMAIL_SYSTEM_TOGGLED
  REPORT_RESOLVED
  UNAUTHORIZED_ACTION_ATTEMPT
}

enum ExamType {
  REAL_PAST_QUESTION
  PRACTICE
  ONE_V_ONE_DUEL
  GROUP_COLLAB
}

enum ExamStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum SessionStatus {
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NotificationType {
  TIME_ALERT
  EMOJI_REACTION
  FINISHED
  PROGRESS_UPDATE
}

enum EmailType {
  EVENING_REMINDER
  SUBSCRIPTION_PROMPT
  STREAK_ALERT
  WELCOME_EMAIL
  VERIFICATION_OTP
  DEVICE_VERIFICATION_OTP
  PASSWORD_RESET_OTP
}

enum ReportIssueType {
  WRONG_ANSWER
  TYPO
  AMBIGUOUS
  IMAGE_MISSING
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT

  DEVICE_REGISTERED
  DEVICE_VERIFIED
  DEVICE_REMOVED

  OTP_SENT
  OTP_VERIFIED
  OTP_FAILED
  PASSWORD_RESET_REQUESTED 

  SESSION_INVALIDATED

  PASSWORD_CHANGED

  SUBSCRIPTION_UPGRADED
  SUBSCRIPTION_CANCELLED
  SUBSCRIPTION_EXPIRED

  ADMIN_DEVICE_RESET
  ADMIN_FORCE_LOGOUT
}


// ============================================
// 1. USER MODEL
// ============================================

model User {
  id                    Int       @id @default(autoincrement())
  email                 String    @unique
  passwordHash          String
  fullName              String

  // === ACCOUNT VERIFICATION ===
  isVerified            Boolean   @default(false)
  verificationToken     String?
  tokenExpiresAt        DateTime?

  // === SECURITY & PASSWORD RESET CONTROLS ===
  passwordResetToken    String?   // Stores the hashed OTP
  passwordResetExpires  DateTime? // When the OTP expires
  lastPasswordChange    DateTime? // To enforce the 15-day rule
  
  otpRequestCount       Int       @default(0) // Tracks daily attempts (Max 3)
  lastOtpRequestDate    DateTime? @db.Date // Resets count if date changes

  // === ROLE ===
  role                  Role      @default(USER)

  // === PERSONALIZATION ===
  aspiringCourse        String?
  targetScore           Int?

  // === SCORE SYSTEM ===
  totalSp               Int       @default(0)
  weeklySp              Int       @default(0)

  // === PREMIUM STATUS ===
  isPremium             Boolean   @default(false)
  subscriptionEndDate   DateTime?

  // === FREE USER LIMITS ===
  hasTakenFreeExam      Boolean   @default(false)
  realExamsCompleted    Int       @default(0)

  // === AI USAGE ===
  aiExplanationsUsedToday Int      @default(0)
  aiLimitResetDate        DateTime @default(now()) @db.Date

  // === STREAKS ===
  currentStreak         Int       @default(0)
  longestStreak         Int       @default(0)
  lastActivityDate      DateTime? @db.Date

  // === EMAIL CONTROL ===
  lastStreakReminder    DateTime? @db.Date
  emailUnsubscribed     Boolean   @default(false)

  // === BAN STATUS ===
  isBanned              Boolean   @default(false)
  bannedAt              DateTime?
  bannedReason          String?

  // === TIMESTAMPS ===
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // ========================================
  // RELATIONSHIPS
  // ========================================

  devices                 UserDevice[]
  sessions                UserSession[]

  exams                   Exam[]
  subscription            Subscription?
  bookmarkedQuestions     BookmarkedQuestion[]
  studyActivities         StudyActivity[]
  emailLogs               EmailLog[]
  hostedSessions          CollaborationSession[] @relation("SessionHost")
  participations          SessionParticipant[]
  sentNotifications       CollaborationNotification[]
  aiRequests              AIExplanationRequest[]
  weeklyLeaderboardEntries WeeklyLeaderboard[]
  questionReports         QuestionReport[]
  auditLogs               AuditLog[]
  adminAuditLogs          AdminAuditLog[]

  @@index([email])
  @@index([totalSp])
  @@index([weeklySp])
  @@index([isPremium])
}

// ============================================
// 2. USER DEVICE MODEL (PRO DEVICE CONTROL)
// ============================================

model UserDevice {
  id           String    @id @default(uuid())
  userId       Int

  deviceId     String
  deviceName   String
  userAgent    String

  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(false)

  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
}

// ============================================
// 3. USER SESSION MODEL (SINGLE ACTIVE LOGIN)
// ============================================

model UserSession {
  id           String    @id @default(uuid())
  userId       Int
  deviceId     String

  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  expiresAt    DateTime?

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
}

// ============================================
// 4. QUESTION MODEL
// ============================================

model Question {
  id               Int       @id @default(autoincrement())
  questionText     String    @db.Text

  hasImage         Boolean   @default(false)
  imageUrl         String?   @db.Text

  optionA          String    @db.Text
  optionB          String    @db.Text
  optionC          String    @db.Text
  optionD          String    @db.Text
  optionE          String?   @db.Text

  optionAImageUrl  String?   @db.Text
  optionBImageUrl  String?   @db.Text
  optionCImageUrl  String?   @db.Text
  optionDImageUrl  String?   @db.Text
  optionEImageUrl  String?   @db.Text

  correctAnswer    String

  subject          String
  topic            String?
  difficultyLevel  String?
  questionType     String

  isAiGenerated    Boolean   @default(false)
  parentQuestionId Int?

  timesAttempted   Int       @default(0)
  timesCorrect     Int       @default(0)

  createdAt        DateTime  @default(now())

  parentQuestion   Question?  @relation("QuestionVariations", fields: [parentQuestionId], references: [id])
  childQuestions   Question[] @relation("QuestionVariations")
  explanation      Explanation?
  examAnswers      ExamAnswer[]
  bookmarks        BookmarkedQuestion[]
  aiRequests       AIExplanationRequest[]
  reports          QuestionReport[]

  @@index([subject])
  @@index([topic])
  @@index([questionType])
}

// ============================================
// 5. QUESTION REPORT
// ============================================

model QuestionReport {
  id          Int            @id @default(autoincrement())
  userId      Int
  questionId  Int

  issueType   ReportIssueType
  description String?        @db.Text
  status      ReportStatus   @default(PENDING)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  question    Question @relation(fields: [questionId], references: [id])

  @@index([status])
  @@index([questionId])
}

// ============================================
// 6. EXPLANATION
// ============================================

model Explanation {
  id                 Int       @id @default(autoincrement())
  questionId         Int       @unique
  explanationText    String    @db.Text
  explanationImageUrl String?  @db.Text
  additionalNotes    String?   @db.Text
  createdAt          DateTime  @default(now())

  question           Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  aiRequests         AIExplanationRequest[]
}

// ============================================
// 7. EXAM
// ============================================

model Exam {
  id                    Int       @id @default(autoincrement())
  userId                Int
  examType              ExamType

  subjectsIncluded      String[]
  totalQuestions        Int

  score                 Int
  percentage            Float?
  spEarned              Int
  timeTakenSeconds      Int?

  isRetake              Boolean    @default(false)
  attemptNumber         Int        @default(1)
  originalExamId        Int?
  maxRetakes            Int        @default(3)

  isCollaboration       Boolean    @default(false)
  collaborationSessionId Int?

  status                ExamStatus @default(COMPLETED)

  startedAt             DateTime   @default(now())
  completedAt           DateTime?

  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  examAnswers           ExamAnswer[]
  collaborationSession  CollaborationSession? @relation(fields: [collaborationSessionId], references: [id])
  bookmarkedQuestions   BookmarkedQuestion[]

  originalExam          Exam?      @relation("ExamRetakes", fields: [originalExamId], references: [id])
  retakes               Exam[]     @relation("ExamRetakes")

  @@index([userId])
  @@index([examType])
  @@index([collaborationSessionId])
  @@index([isRetake])
}

// ============================================
// 8. EXAM ANSWER
// ============================================

model ExamAnswer {
  id               Int       @id @default(autoincrement())
  examId           Int
  questionId       Int

  userAnswer       String?
  isCorrect        Boolean
  timeSpentSeconds Int?
  answeredAt       DateTime  @default(now())

  exam             Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  question         Question  @relation(fields: [questionId], references: [id])

  @@index([examId])
  @@index([questionId])
}

// ============================================
// 9. BOOKMARK
// ============================================

model BookmarkedQuestion {
  id          Int       @id @default(autoincrement())
  userId      Int
  questionId  Int
  examId      Int?
  notes       String?   @db.Text

  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  exam        Exam?    @relation(fields: [examId], references: [id], onDelete: SetNull)

  @@unique([userId, questionId])
  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// 10. AI EXPLANATION REQUEST
// ============================================

model AIExplanationRequest {
  id                    Int       @id @default(autoincrement())
  userId                Int
  questionId            Int
  originalExplanationId Int?

  aiResponse            String    @db.Text
  tokensUsed            Int?
  costUsd               Float?
  wasHelpful            Boolean?
  userRating            Int?
  createdAt             DateTime  @default(now())

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  question              Question  @relation(fields: [questionId], references: [id])
  originalExplanation   Explanation? @relation(fields: [originalExplanationId], references: [id])

  @@index([userId])
}

// ============================================
// 11. WEEKLY LEADERBOARD
// ============================================

model WeeklyLeaderboard {
  id            Int      @id @default(autoincrement())
  userId        Int
  weekStartDate DateTime @db.Date
  weekEndDate   DateTime @db.Date
  weeklySp      Int      @default(0)
  rank          Int?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStartDate])
  @@index([weekStartDate])
  @@index([weeklySp])
}

// ============================================
// 12. COLLAB SESSION
// ============================================

model CollaborationSession {
  id                 Int               @id @default(autoincrement())
  sessionType        String
  hostUserId         Int
  sessionCode        String            @unique

  subjectsIncluded   String[]
  totalQuestions     Int
  questionSource     String            @default("real_past_question")

  status             SessionStatus     @default(WAITING)
  isLocked           Boolean           @default(false)
  maxParticipants    Int?

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  startedAt          DateTime?
  endedAt            DateTime?

  host               User              @relation("SessionHost", fields: [hostUserId], references: [id])
  participants       SessionParticipant[]
  exams              Exam[]
  notifications      CollaborationNotification[]

  @@index([hostUserId])
  @@index([sessionCode])
}

// ============================================
// 13. SESSION PARTICIPANT
// ============================================

model SessionParticipant {
  id           Int      @id @default(autoincrement())
  sessionId    Int
  userId       Int

  score        Int?
  spEarned     Int?
  finalRank    Int?

  joinedAt     DateTime @default(now())
  finishedAt   DateTime?

  session      CollaborationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([sessionId])
}

// ============================================
// 14. COLLAB NOTIFICATION
// ============================================

model CollaborationNotification {
  id               Int              @id @default(autoincrement())
  sessionId        Int
  fromUserId       Int
  notificationType NotificationType
  notificationData Json?
  createdAt        DateTime         @default(now())

  session          CollaborationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fromUser         User                 @relation(fields: [fromUserId], references: [id])

  @@index([sessionId])
}

// ============================================
// 15. SUBSCRIPTION
// ============================================

model Subscription {
  id               Int                @id @default(autoincrement())
  userId           Int                @unique
  planType         String
  amountPaid       Decimal            @db.Decimal(10, 2)
  paymentReference String?            @unique
  status           SubscriptionStatus @default(ACTIVE)
  startDate        DateTime
  endDate          DateTime
  autoRenew        Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([endDate])
}

// ============================================
// 16. STUDY ACTIVITY
// ============================================

model StudyActivity {
  id            Int      @id @default(autoincrement())
  userId        Int
  activityDate  DateTime @db.Date
  examsTaken    Int      @default(0)
  spEarnedToday Int      @default(0)
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, activityDate])
  @@index([userId])
}

// ============================================
// 17. EMAIL LOG
// ============================================

model EmailLog {
  id             Int       @id @default(autoincrement())
  userId         Int
  emailType      EmailType
  sentAt         DateTime  @default(now())
  status         String    @default("sent")
  emailServiceId String?

  opened         Boolean   @default(false)
  clicked        Boolean   @default(false)

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sentAt])
}

// ============================================
// 18. SYSTEM SETTINGS (Singleton)
// ============================================
// Global platform settings controlled by SUPERADMIN only
// CRITICAL: Only row id=1 should ever exist. Enforce at runtime.

model SystemSettings {
  id               Int      @id @default(1) // Singleton enforcement
  
  // Email and notification controls
  emailEnabled     Boolean  @default(true)
  pauseReminders   Boolean  @default(false)
  
  // System state
  maintenanceMode  Boolean  @default(false)
  
  // Audit
  updatedAt        DateTime @updatedAt
  updatedByUserId  Int?     // Last SUPERADMIN who modified
}

// ============================================
// 19. AUDIT LOG
// ============================================ 
model AuditLog {
  id          BigInt   @id @default(autoincrement())

  userId      Int?    // nullable for failed login attempts
  action      AuditAction

  deviceId    String?
  ipAddress   String?
  userAgent   String?

  metadata    Json?   // flexible: examId, amountPaid, reason, etc.

  createdAt   DateTime @default(now())

  user        User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ============================================
// 20. ADMIN AUDIT LOG (Security-Critical)
// ============================================
// Separate from user AuditLog for admin/superadmin actions
// Actor role is snapshotted at action time for historical accuracy

model AdminAuditLog {
  id          Int       @id @default(autoincrement())
  
  actorId     Int
  actorRole   String    // Snapshot of role at action time
  action      AdminAuditAction
  
  targetType  String    // 'USER', 'QUESTION', 'DEVICE', 'SYSTEM', 'REPORT'
  targetId    String?   // ID of affected entity (string for flexibility)
  
  metadata    Json?     // Additional context (old/new values, etc.)
  reason      String?   // Optional justification for the action
  ipAddress   String?
  
  createdAt   DateTime  @default(now())
  
  actor       User      @relation(fields: [actorId], references: [id])
  
  @@index([actorId])
  @@index([action])
  @@index([targetType])
  @@index([createdAt])
}