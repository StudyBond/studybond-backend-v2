{
  "name": "studybond-backend",
  "version": "1.0.0",
  "description": "StudyBond Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "npm run prisma:generate && tsc",
    "start": "node dist/server.js",
    "openapi:export": "node scripts/export-openapi.js",
    "openapi:types": "openapi-typescript artifacts/openapi/openapi.json -o artifacts/openapi/openapi-types.d.ts",
    "openapi:sync": "npm run build && npm run openapi:export && npm run openapi:types",
    "seed:admin-user": "node scripts/seed-admin-user.js",
    "seed:admin": "node scripts/seed-admin-user.js --role=ADMIN",
    "seed:superadmin": "node scripts/seed-admin-user.js --role=SUPERADMIN",
    "seed:founder": "node scripts/seed-founder.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "node scripts/prisma-migrate-deploy.js",
    "prisma:migrate:deploy:integration": "node scripts/prisma-migrate-deploy.js --integration",
    "prisma:migrate:status": "node scripts/prisma-migrate-status.js",
    "prisma:migrate:status:integration": "node scripts/prisma-migrate-status.js --integration",
    "prisma:migrate:resolve": "node scripts/prisma-migrate-resolve.js",
    "prisma:migrate:resolve:integration": "node scripts/prisma-migrate-resolve.js --integration",
    "institution:verify:backfill": "node scripts/verify-institution-backfill.js",
    "institution:verify:backfill:integration": "node scripts/verify-institution-backfill.js --integration",
    "normalize:subjects": "node scripts/normalize-subjects.js",
    "prisma:studio": "prisma studio",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "node scripts/run-integration-tests.js",
    "load:smoke": "k6 run load-tests/smoke.js",
    "load:mixed": "k6 run load-tests/mixed-profile.js",
    "load:leaderboard": "k6 run load-tests/leaderboard-read-storm.js",
    "worker:leaderboard": "ts-node-dev --transpile-only src/workers/leaderboard.worker.ts",
    "worker:leaderboard:once": "ts-node-dev --transpile-only src/workers/leaderboard.worker.ts --once"
  },
  "keywords": [
    "studybond",
    "education",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.0.6",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "openapi-typescript": "^7.13.0",
    "prisma": "^7.2.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.3.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/redis": "^7.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.2.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.3.0",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3",
    "pino": "^10.1.1",
    "pino-pretty": "^13.1.3",
    "xlsx": "^0.18.5",
    "zod": "^4.3.5"
  }
}
