NODE_ENV=development
PORT=5000
HOST=0.0.0.0

DATABASE_URL="postgresql://postgres:password@localhost:5432/studybondDB?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/studybondDB?schema=public"
INTEGRATION_DATABASE_URL="postgresql://postgres:password@localhost:5432/studybondDB_test?schema=public"
INTEGRATION_DIRECT_URL="postgresql://postgres:password@localhost:5432/studybondDB_test?schema=public"
INTEGRATION_AUTO_MIGRATE=false
INTEGRATION_REDIS_ENABLED=false
INTEGRATION_REDIS_URL=redis://127.0.0.1:6379
PGCONNECT_TIMEOUT_MS=15000

JWT_SECRET=generate_your_own_secret
JWT_EXPIRY=15m
REFRESH_TOKEN_SECRET=generate_your_own_secret
REFRESH_TOKEN_EXPIRY=30d
AUTH_TX_MAX_WAIT_MS=10000
AUTH_TX_TIMEOUT_MS=20000

RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_NAMESPACE=studybond:rate-limit
EXAM_START_RATE_LIMIT_MAX=5
EXAM_START_RATE_LIMIT_WINDOW_SECONDS=60
EXAM_SUBMIT_LOCK_TTL_SECONDS=30
EXAM_HISTORY_CACHE_TTL_SECONDS=45
COLLAB_IDEMPOTENCY_TTL_SECONDS=86400
COLLAB_START_LOCK_TTL_SECONDS=20
COLLAB_JOIN_LOCK_TTL_SECONDS=20
COLLAB_EVENT_DEDUPE_TTL_SECONDS=90
COLLAB_HEARTBEAT_DB_SYNC_SECONDS=60
COLLAB_TX_MAX_WAIT_MS=10000
COLLAB_TX_TIMEOUT_MS=20000
WS_MAX_PAYLOAD_BYTES=65536
WS_OWNER_TTL_SECONDS=75
WS_OWNER_REFRESH_SECONDS=25
WS_SLOW_CONSUMER_MAX_QUEUE=128
WS_SLOW_CONSUMER_DISCONNECT_THRESHOLD=256
WS_BUFFERED_AMOUNT_SOFT_LIMIT=262144
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_ENFORCEMENT_STRICT=false
METRICS_TOKEN=change_me_for_staging_and_prod
AUTH_LOGIN_RATE_LIMIT_MAX=8
AUTH_VERIFY_OTP_RATE_LIMIT_MAX=12
AUTH_REFRESH_RATE_LIMIT_MAX=40
AUTH_REGISTER_RATE_LIMIT_MAX=6
AUTH_FORGOT_PASSWORD_RATE_LIMIT_MAX=5
AUTH_RESEND_RESET_PASSWORD_RATE_LIMIT_MAX=5
AUTH_RESET_PASSWORD_RATE_LIMIT_MAX=10
AUTH_PASSWORD_RESET_OTP_EXPIRY_SECONDS=600
AUTH_PASSWORD_RESET_RESEND_COOLDOWN_SECONDS=60
AUTH_PASSWORD_CHANGE_DAILY_LIMIT=3
AUTH_PASSWORD_RESET_MAX_EMAILS_PER_HOUR=3
AUTH_PASSWORD_RESET_MAX_REQUESTS_PER_IP_PER_HOUR=10
AUTH_PASSWORD_RESET_MAX_VERIFY_ATTEMPTS=5
AUTH_PASSWORD_CHANGE_ALERT_DELAY_MINUTES=30
AUTH_PASSWORD_CHANGE_ALERT_CRON=*/10 * * * *
AUTH_PASSWORD_CHANGE_ALERT_BATCH_SIZE=100
DEV_OTP_PREVIEW_ENABLED=false
DEV_TOOLS_TOKEN=replace_with_a_long_random_non_production_token
DEV_OTP_PREVIEW_TTL_SECONDS=1800
DEV_OTP_PREVIEW_LIST_LIMIT_MAX=20
DEV_OTP_PREVIEW_SCAN_LIMIT=200
DEV_OTP_PREVIEW_REDIS_BATCH_SIZE=50
FOUNDER_ADMIN_EMAIL=
FOUNDER_ADMIN_NAME=
FOUNDER_ADMIN_PASSWORD=
FOUNDER_ADMIN_INSTITUTION=UI
ADMIN_PREMIUM_MUTATION_TX_TIMEOUT_MS=45000
ADMIN_ANALYTICS_ROLLUP_CRON=*/20 * * * *
ADMIN_ANALYTICS_ROLLUP_LOOKBACK_DAYS=35
ADMIN_USER_360_RECENT_LIMIT=5
ADMIN_USER_360_AUDIT_LIMIT=10
BOOKMARK_EXPIRY_CLEANUP_CRON=*/30 * * * *
BOOKMARK_EXPIRY_CLEANUP_BATCH_SIZE=500
BOOKMARK_EXPIRY_CLEANUP_MAX_BATCHES=20
LAUNCH_INSTITUTION_CODE=UI
STREAK_REMINDER_CRON=0 21 * * *
STREAK_REMINDER_BATCH_SIZE=100
STREAK_RECONCILIATION_CRON=5 * * * *
STREAK_RECONCILIATION_BATCH_SIZE=500
STREAK_RECONCILIATION_MAX_BATCHES=20
STREAK_CALENDAR_DEFAULT_DAYS=30
STREAK_CALENDAR_MAX_DAYS=90
STREAK_FREE_PROMPT_COOLDOWN_DAYS=7
LEADERBOARD_CACHE_TTL_SECONDS=60
LEADERBOARD_DEFAULT_LIMIT=50
LEADERBOARD_MAX_LIMIT=50
LEADERBOARD_PROJECTION_ENABLED=false
LEADERBOARD_REDIS_READ_ENABLED=false
LEADERBOARD_TIE_BUFFER=20
LEADERBOARD_PROJECTION_STALE_SECONDS=120
LEADERBOARD_WORKER_BATCH_SIZE=200
LEADERBOARD_WORKER_POLL_INTERVAL_MS=800
LEADERBOARD_WORKER_MAX_ATTEMPTS=8
LEADERBOARD_WORKER_RECONCILE_INTERVAL_SECONDS=300
LEADERBOARD_WORKER_RECONCILE_TOP_N=100
LEADERBOARD_WORKER_RECONCILE_SAMPLE_SIZE=20
LEADERBOARD_WEEKLY_RESET_CRON=59 23 * * 0
LEADERBOARD_SIGNAL_HIGH_SCORE_PERCENT=90
LEADERBOARD_SIGNAL_LOW_TIME_SECONDS_PER_QUESTION=8
LEADERBOARD_SIGNAL_SP_VELOCITY_LIMIT_5M=25
JOBS_ENABLED=false
SWAGGER_ENABLED=true
PUBLIC_API_BASE_URL=http://localhost:5000
JOBS_TIMEZONE=Africa/Lagos

REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379

CORS_ORIGIN=http://localhost:3000

